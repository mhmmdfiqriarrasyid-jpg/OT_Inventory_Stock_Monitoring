rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return userDoc().role;
    }

    function isActive() {
      return userDoc().active != false;
    }

    function isAdmin()   { return isAuthed() && isActive() && role() == 'admin'; }
    function isManager() { return isAuthed() && isActive() && role() in ['admin', 'manager']; }
    function isViewer()  { return isAuthed() && isActive() && role() in ['admin', 'manager', 'viewer']; }

    // ── users ─────────────────────────────────────────────────────────────────
    // • Any authenticated user can create their own profile on first sign-in
    // • Users can read their own profile; admins can read all
    // • Users cannot change their own role; only admins can change roles
    // • Only admins can delete user docs or toggle active flag

    match /users/{uid} {
      allow read:   if isAuthed() && (request.auth.uid == uid || isAdmin());
      allow create: if isAuthed() && request.auth.uid == uid;
      allow update: if isAuthed() && (
        // Admin can change anything
        isAdmin()
        ||
        // User can update their own profile but NOT role or active flag
        (
          request.auth.uid == uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'active'])
        )
      );
      allow delete: if isAdmin();
    }

    // ── categories ────────────────────────────────────────────────────────────
    // Viewers: read only   |   Managers + Admins: full CRUD

    match /categories/{id} {
      allow read:   if isViewer();
      allow create,
            update,
            delete: if isManager();
    }

    // ── items ─────────────────────────────────────────────────────────────────
    // Viewers: read only   |   Managers + Admins: full CRUD

    match /items/{id} {
      allow read:   if isViewer();
      allow create,
            update: if isManager();
      allow delete: if isAdmin();
    }

    // ── transactions ──────────────────────────────────────────────────────────
    // Viewers: read only   |   Managers: create only (no edit/delete)
    // Only Admins can update or delete past transaction records

    match /transactions/{id} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update,
            delete: if isAdmin();
    }
  }
}
